# Copy this file to ".env" in the same folder, then fill in the real value.

# Your Neon PostgreSQL connection string (Part 2 of the guide shows exactly
# where to copy this from). Keep the quotes out, keep it on one line.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Your free OpenRouter API key — this is what powers the AI chat agent.
# Part 2 of the guide shows exactly where to get this and paste it here.
OPENROUTER_API_KEY=paste-your-openrouter-key-here

# Port for running locally. Vercel ignores this in production.
PORT=5000

# Optional: only needed if your frontend is ever hosted on a different
# domain than the backend. Leave this commented out otherwise.
# ALLOWED_ORIGIN=https://your-site.vercel.app
